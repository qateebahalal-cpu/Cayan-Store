rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 3. Path Variable Hardening
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'asdsamali111@gmail.com' || // Bootstrapped Admin
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 2. Validation Blueprints
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'createdAt']) &&
             data.keys().size() >= 3 &&
             data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 100 &&
             data.createdAt == request.time;
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'category', 'image']) &&
             data.name is string && data.name.size() <= 100 &&
             data.price is number && data.price >= 0 &&
             data.category is string &&
             data.image is string;
    }

    function isValidCategory(data) {
      return data.keys().hasAll(['name', 'icon']) &&
             data.name is string && data.name.size() <= 64 &&
             data.icon is string;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['userId', 'items', 'total', 'status', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.items is list && data.items.size() > 0 && data.items.size() <= 50 &&
             data.total is number && data.total >= 0 &&
             data.status == 'pending' &&
             data.createdAt == request.time;
    }

    function isValidReview(data) {
      return data.keys().hasAll(['productId', 'userId', 'userName', 'userImage', 'rating', 'comment', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.productId is string &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             data.comment is string && data.comment.size() <= 1000 &&
             data.createdAt == request.time;
    }

    // --- Collections ---

    // Users
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && 
                      incoming().diff(existing()).affectedKeys().hasOnly(['displayName']) &&
                      incoming().uid == existing().uid &&
                      incoming().email == existing().email;
    }

    // Products
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin() && (request.method == 'create' || request.method == 'update') && isValidProduct(incoming());
      allow delete: if isAdmin();
    }

    // Categories
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin() && (request.method == 'create' || request.method == 'update') && isValidCategory(incoming());
      allow delete: if isAdmin();
    }

    // Orders
    match /orders/{orderId} {
      allow get: if isOwner(existing().userId) || isAdmin();
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidOrder(incoming());
      allow update: if isAdmin() && 
                      incoming().diff(existing()).affectedKeys().hasOnly(['status']) &&
                      incoming().status in ['processing', 'shipped', 'delivered', 'cancelled'];
    }

    // Reviews
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidReview(incoming());
      allow update: if isOwner(existing().userId) &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['rating', 'comment']) &&
                      incoming().rating is number && incoming().rating >= 1 && incoming().rating <= 5 &&
                      incoming().comment is string && incoming().comment.size() <= 1000;
      allow delete: if isOwner(existing().userId) || isAdmin();
    }

    // Admins helper collection
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable via console or service account
    }
  }
}
